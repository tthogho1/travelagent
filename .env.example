# Copy this file to `.env` and fill in your real keys.
# `.env` is gitignored and loaded automatically by travel_agent.py.

OPENAI_API_KEY=your-openai-api-key
DUFFEL_API_KEY=your-duffel-api-key
# LiteAPI key for hotel search (sandbox or production).
LITEAPI_API_KEY=your-liteapi-key

# Agent model (default: o3). Any OpenAI chat/reasoning model id works, e.g.
# gpt-4o, gpt-4.1, o3, o4-mini.
OPENAI_MODEL=o3

# Databricks Vector Search (used by agents/cities.py search_cities)
WORKSPACE_URL=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your-databricks-pat

# Optional search_cities overrides (defaults shown)
CITIES_LLM_MODEL=databricks-meta-llama-3-3-70b-instruct
CITIES_ENDPOINT_NAME=wikivoyage_seach_endpoint
CITIES_INDEX_NAME=workspace.default.wikivoyage_index
CITIES_COLUMNS=content,title
CITIES_NUM_RESULTS=3

# Optional agent run logging (defaults shown)
LOG_LEVEL=INFO
LOG_FILE=agent.log

# Optional geocode_location (OpenStreetMap Nominatim) overrides (defaults shown)
# Nominatim requires a descriptive User-Agent identifying your app + contact.
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_USER_AGENT=travelagent-geocoder/1.0 (you@example.com)
GEOCODING_NUM_RESULTS=5
